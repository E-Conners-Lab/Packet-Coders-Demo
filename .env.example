# Copy to .env and edit as needed:  cp .env.example .env
# docker compose / make automatically read .env from the repo root.
# (.env is git-ignored — your real values never get committed.)

# --- Host port for the mcpo tool server -------------------------------------
# Open WebUI connects to http://localhost:${MCPO_PORT}. Change this if port 8000
# is already in use on your machine (e.g. another container owns it).
MCPO_PORT=8000

# --- Which inventory the lab tools use --------------------------------------
# Default is the mock lab (no hardware). To drive a REAL lab, copy
# configs/inventory.eve-ng.example.yaml to configs/inventory.local.yaml
# (git-ignored, auto-mounted into the container) and point this at it:
#   PACKET_CODERS_INVENTORY=/app/configs/inventory.local.yaml
PACKET_CODERS_INVENTORY=/app/configs/inventory.mock.yaml

# --- Config-write tool ------------------------------------------------------
# true  = configure_device is exposed (still gated by an out-of-band code)
# false = configure_device is not advertised at all (strictly read-only)
PACKET_CODERS_ALLOW_WRITES=true

# --- Model backend ----------------------------------------------------------
# Bundled Ollama (plain `docker compose up`) leaves this as-is.
# `make up-host` overrides it to your host's Ollama (Metal GPU on a Mac).
OLLAMA_BASE_URL=http://ollama:11434

# Model pulled into the BUNDLED Ollama by `docker compose up` (the model-init
# one-shot). NOTE: `make up-host` does NOT pull anything — it uses your host
# Ollama, so run `ollama pull qwen3:8b` (or use a model you already have).
LLM_MODEL=qwen3:8b
